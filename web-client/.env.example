# MQTT Configuration
# Copy this file to .env and fill in your actual credentials

VITE_MQTT_BROKER=your_broker_address
VITE_MQTT_PORT=your_port_number
VITE_MQTT_USERNAME=your_username
VITE_MQTT_PASSWORD=your_password

# MQTT State Mode
# false = Dev Mode (Optimistic UI) - UI updates immediately on click
# true = Production Mode (Real MQTT) - UI waits for MQTT response from device
VITE_IS_USING_MQTT_STATE=true

# MQTT Client ID (unique per machine/user)
# Use different IDs for different machines/users to avoid conflicts
VITE_MQTT_CLIENT_ID=web-client-your-name

# ThingSpeak Configuration
# Get your Channel ID and Read API Key from https://thingspeak.com/
# Channels > My Channels > API Keys tab
VITE_THINGSPEAK_CHANNEL_ID=your_channel_id_here
VITE_THINGSPEAK_READ_API_KEY=your_read_api_key_here
